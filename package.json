{
  "name": "copilot-remote",
  "version": "1.0.0",
  "type": "module",
  "description": "Web proxy for GitHub Copilot CLI — relay messages between browser and CLI",
  "main": "server/server.js",
  "bin": {
    "copilot-remote": "./bin/copilot-remote.js"
  },
  "scripts": {
    "start": "node server/start.js",
    "start:server": "node server/server.js",
    "start:server:respawn": "server\\respawn.bat",
    "start:server:respawn:posix": "bash server/respawn.sh",
    "copilot:relay": "gh copilot -- --allow-all",
    "test:e2e": "node tests/run-e2e.mjs",
    "test:e2e:raw": "node ./node_modules/@playwright/test/cli.js test --config tests/playwright.config.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.5",
    "uuid": "^14.0.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "tty-console": "^1.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
